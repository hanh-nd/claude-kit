{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_HOME:-$HOME/.codex}/plugins/cache/agent-kit/agent-kit/local/scripts/kit-init.js\"",
            "statusMessage": "Initializing Agent Kit",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"${CODEX_HOME:-$HOME/.codex}/plugins/cache/agent-kit/agent-kit/local/scripts/inject-agent-instructions.js\"",
            "statusMessage": "Loading Agent Kit instructions",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_HOME:-$HOME/.codex}/plugins/cache/agent-kit/agent-kit/local/scripts/inject-agent-instructions.js\"",
            "statusMessage": "Loading Agent Kit instructions",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_HOME:-$HOME/.codex}/plugins/cache/agent-kit/agent-kit/local/scripts/security-privacy.js\"",
            "statusMessage": "Checking prompt for sensitive paths",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_HOME:-$HOME/.codex}/plugins/cache/agent-kit/agent-kit/local/scripts/security-privacy.js\"",
            "statusMessage": "Checking tool input for sensitive paths",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_HOME:-$HOME/.codex}/plugins/cache/agent-kit/agent-kit/local/scripts/wiki-inbox-append.js\"",
            "statusMessage": "Updating Agent Kit wiki inbox",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_HOME:-$HOME/.codex}/plugins/cache/agent-kit/agent-kit/local/scripts/export-conversation-history.js\"",
            "statusMessage": "Exporting Agent Kit conversation history",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
