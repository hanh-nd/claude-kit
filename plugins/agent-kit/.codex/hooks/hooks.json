{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/kit-init.js",
            "statusMessage": "Initializing Agent Kit",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/inject-agent-instructions.js",
            "statusMessage": "Loading Agent Kit instructions",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/inject-agent-instructions.js",
            "statusMessage": "Loading Agent Kit instructions",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/security-privacy.js",
            "statusMessage": "Checking prompt for sensitive paths",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/security-privacy.js",
            "statusMessage": "Checking tool input for sensitive paths",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
