{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "name": "kit-init",
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/scripts/kit-init.js",
            "description": "Initialize Agent-Kit",
            "timeout": 10000
          },
          {
            "name": "inject-instructions",
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/scripts/inject-agent-instructions.js",
            "description": "Inject agent instructions at session start",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "name": "inject-instructions",
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/scripts/inject-agent-instructions.js",
            "description": "Inject agent instructions after /clear",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "name": "security-blocker",
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/scripts/security-privacy.js",
            "description": "Hard-block access to sensitive files",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "name": "security-blocker",
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/scripts/security-privacy.js",
            "description": "Hard-block access to sensitive files",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "name": "inject-instructions",
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/scripts/inject-agent-instructions.js",
            "description": "Inject agent instructions after /compact",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
