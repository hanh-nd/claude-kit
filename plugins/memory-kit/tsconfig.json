{
  "compilerOptions": {
    "target": "es2023",
    "module": "ESNext",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@types": ["types/index.ts"]
    },
    "outDir": "./dist",
    "rootDir": "./",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": true
  },
  "include": [
    "test-scripts/**/*",
    "scripts/**/*",
    "utils/**/*",
    "tests/**/*",
    "types/**/*"
  ]
}
