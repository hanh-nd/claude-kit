{
  "compilerOptions": {
    "target": "es2023",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true
  },
  "include": [
    "scripts/**/*",
    "utils/**/*",
    "tests/**/*"
  ]
}