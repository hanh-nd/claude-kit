{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "name": "memory-kit-init",
            "type": "command",
            "command": "node \"${extensionPath}/scripts/kit-init.js\"",
            "timeout": 10000
          },
          {
            "name": "memory-kit-digest-pending",
            "type": "command",
            "command": "npx -y @hanhnd/agent-kit-cli@latest memory digest-pending --hook",
            "timeout": 180000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "exit|clear",
        "hooks": [
          {
            "name": "memory-kit-session-end",
            "type": "command",
            "command": "node \"${extensionPath}/scripts/kit-session-end.js\"",
            "timeout": 30000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "kit_save_handoff",
        "hooks": [
          {
            "name": "memory-kit-handoff-saved",
            "type": "command",
            "command": "node \"${extensionPath}/scripts/kit-handoff-saved.js\"",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}