{
  "name": "@hanhnd/memory-kit",
  "version": "1.0.0",
  "description": "Memory Kit - Native TypeScript persistent memory for agent-kit",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hanh-nd/agent-kit.git"
  },
  "scripts": {
    "build:plugin": "node dist/utils/build-plugin.js",
    "prepublishOnly": "npm run build:plugin",
    "build": "tsc && npm run build:plugin",
    "test": "tsc && node --test $(find dist/tests -name '*.test.js' | tr '\\n' ' ')"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
