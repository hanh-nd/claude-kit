{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "name": "memory-kit-init",
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/scripts/kit-init.js",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "name": "memory-kit-session-end",
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/scripts/kit-session-end.js",
            "timeout": 30000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_ak_kit-agents__kit_save_handoff",
        "hooks": [
          {
            "name": "memory-kit-handoff-saved",
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/scripts/kit-handoff-saved.js",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}