{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/kit-init.js",
            "statusMessage": "Initializing Memory Kit",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "npx -y @hanhnd/agent-kit-cli@latest memory digest-pending --hook",
            "statusMessage": "Digesting pending conversations",
            "timeout": 180
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/kit-session-end.js",
            "statusMessage": "Saving session summary to memory",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "kit_save_handoff",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/kit-handoff-saved.js",
            "statusMessage": "Logging handoff to wiki inbox",
            "timeout": 10
          }
        ]
      }
    ]
  }
}