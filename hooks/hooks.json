{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "name": "kit-init",
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT\"/hooks/session-start.js",
            "description": "Initialize Agent-Kit",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "name": "inject-project-dna",
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT\"/hooks/prompt-submit.js",
            "description": "Inject project DNA into context for command invocations",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
