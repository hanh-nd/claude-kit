{
  "name": "@hanhnd/agent-suite",
  "version": "1.0.0",
  "description": "Marketplace of AI Agents for software development",
  "private": true,
  "workspaces": [
    "mcp",
    "plugins/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "publish:mcp": "npm publish --workspace @hanhnd/agent-kit",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hanh-nd/agent-kit.git"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
