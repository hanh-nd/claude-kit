{
  "name": "@hanhnd/agent-kit",
  "version": "1.0.30",
  "description": "Agent Kit MCP server for software development agent workflows",
  "type": "module",
  "main": "dist/kit-server.js",
  "bin": {
    "agent-kit": "dist/kit-server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hanh-nd/agent-kit.git",
    "directory": "mcp"
  },
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "esbuild src/kit-server.ts --bundle --platform=node --format=esm --outfile=dist/kit-server.js --external:node:* --external:better-sqlite3 --external:sqlite-vec --external:fastembed --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "tsc && node --test $(find dist/src/memory/__tests__ dist/src/tools/__tests__ -name '*.test.js' 2>/dev/null | tr '\\n' ' ')"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.1",
    "better-sqlite3": "^11.0.0",
    "dedent": "^1.5.3",
    "fastembed": "^1.14.0",
    "sqlite-vec": "^0.1.0",
    "stopword": "^3.1.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.4",
    "typescript": "^5.8.3"
  }
}
